{% # theme-check-disable %}
{%- assign body_font_light = settings.type_body_font | font_modify: 'weight', '300' -%}
{%- assign body_font_semibold = settings.type_body_font | font_modify: 'weight', '600' -%}
{%- unless settings.type_body_font.system? -%}
  <link
    rel="preload"
    as="font"
    href="{{ settings.type_body_font | font_url }}"
    type="font/woff2"
    crossorigin
    fetchpriority="low"
  >
{%- endunless -%}
{%- if body_font_light and body_font_light.system? == false -%}
  <link
    rel="preload"
    as="font"
    href="{{ body_font_light | font_url }}"
    type="font/woff2"
    crossorigin
    fetchpriority="low"
  >
{%- endif -%}
{%- if body_font_semibold and body_font_semibold.system? == false -%}
  <link
    rel="preload"
    as="font"
    href="{{ body_font_semibold | font_url }}"
    type="font/woff2"
    crossorigin
    fetchpriority="low"
  >
{%- endif -%}
{%- unless settings.type_subheading_font.system? -%}
  <link
    rel="preload"
    as="font"
    href="{{ settings.type_subheading_font | font_url }}"
    type="font/woff2"
    crossorigin
    fetchpriority="low"
  >
{%- endunless -%}
{%- unless settings.type_heading_font.system? -%}
  <link
    rel="preload"
    as="font"
    href="{{ settings.type_heading_font | font_url }}"
    type="font/woff2"
    crossorigin
    fetchpriority="low"
  >
{%- endunless -%}
{%- unless settings.type_accent_font.system? -%}
  <link
    rel="preload"
    as="font"
    href="{{ settings.type_accent_font | font_url }}"
    type="font/woff2"
    crossorigin
    fetchpriority="low"
  >
{%- endunless -%}
{% # theme-check-enable %}
