{{ 'section-bloomy-hero-banner.css' | asset_url | stylesheet_tag }}

{% liquid
  assign banner_alt = section.settings.image_alt | strip
  assign badge_alt = section.settings.badge_alt | strip
  assign loading = 'lazy'
  assign fetch_priority = 'auto'
  assign desktop_widths = '750, 900, 1200, 1600, 2000, 2400'
  assign mobile_widths = '480, 640, 900, 1200'
  assign image_sizes = '(min-width: 1200px) 1200px, (min-width: 750px) calc(100vw - 48px), calc(100vw - 32px)'
  assign mobile_widths_array = mobile_widths | split: ', '

  if banner_alt == blank
    if section.settings.desktop_image != blank
      assign banner_alt = section.settings.desktop_image.alt
    elsif section.settings.mobile_image != blank
      assign banner_alt = section.settings.mobile_image.alt
    endif
  endif

  if badge_alt == blank and section.settings.badge_image != blank
    assign badge_alt = section.settings.badge_image.alt
  endif

  if section.index == 1
    assign loading = 'eager'
    assign fetch_priority = 'high'
  endif
%}

<div
  id="BloomyHeroBanner-{{ section.id }}"
  class="section section--page-width bloomy-hero-banner"
>
  <div class="bloomy-hero-banner__frame">
    <div class="bloomy-hero-banner__media">
      {% if section.settings.desktop_image != blank and section.settings.mobile_image != blank %}
        <picture class="bloomy-hero-banner__picture">
          <source
            media="(max-width: 749px)"
            srcset="
              {%- for mobile_width in mobile_widths_array -%}
                {{ section.settings.mobile_image | image_url: width: mobile_width }} {{ mobile_width }}w{% unless forloop.last %}, {% endunless %}
              {%- endfor -%}
            "
            sizes="{{ image_sizes }}"
          >
          {{
            section.settings.desktop_image
            | image_url: width: 2400
            | image_tag:
              class: 'bloomy-hero-banner__image',
              widths: desktop_widths,
              sizes: image_sizes,
              loading: loading,
              fetchpriority: fetch_priority,
              alt: banner_alt
          }}
        </picture>
      {% elsif section.settings.desktop_image != blank %}
        {{
          section.settings.desktop_image
          | image_url: width: 2400
          | image_tag:
            class: 'bloomy-hero-banner__image',
            widths: desktop_widths,
            sizes: image_sizes,
            loading: loading,
            fetchpriority: fetch_priority,
            alt: banner_alt
        }}
      {% elsif section.settings.mobile_image != blank %}
        {{
          section.settings.mobile_image
          | image_url: width: 1600
          | image_tag:
            class: 'bloomy-hero-banner__image',
            widths: mobile_widths,
            sizes: image_sizes,
            loading: loading,
            fetchpriority: fetch_priority,
            alt: banner_alt
        }}
      {% else %}
        {{ 'image' | placeholder_svg_tag: 'bloomy-hero-banner__placeholder' }}
      {% endif %}
    </div>

    <div class="bloomy-hero-banner__inner">
      <div class="bloomy-hero-banner__content">
        {% if section.settings.badge_image != blank %}
          {{
            section.settings.badge_image
            | image_url: width: 240
            | image_tag:
              class: 'bloomy-hero-banner__badge',
              widths: '120, 180, 240',
              sizes: '(max-width: 749px) 84px, 140px',
              loading: 'lazy',
              alt: badge_alt
          }}
        {% endif %}

        {% if section.settings.heading != blank %}
          <h2 class="bloomy-hero-banner__heading">
            {{ section.settings.heading | escape | newline_to_br }}
          </h2>
        {% endif %}

        {% if section.settings.description != blank %}
          <p class="bloomy-hero-banner__description">
            {{ section.settings.description | escape | newline_to_br }}
          </p>
        {% endif %}

        {% if section.settings.button_label != blank %}
          <a
            class="bloomy-hero-banner__button"
            {% if section.settings.button_link != blank %}
              href="{{ section.settings.button_link }}"
            {% else %}
              aria-disabled="true"
            {% endif %}
          >
            {{ section.settings.button_label | escape }}
          </a>
        {% endif %}
      </div>

      {% if section.blocks.size > 0 %}
        <div class="bloomy-hero-banner__attributes">
          {% for block in section.blocks %}
            {% liquid
              assign icon_alt = block.settings.icon_alt | strip

              if icon_alt == blank and block.settings.icon_image != blank
                assign icon_alt = block.settings.icon_image.alt
              endif
            %}

            {% if block.settings.label != blank or block.settings.icon_image != blank %}
              <div
                class="bloomy-hero-banner__attribute"
                {{ block.shopify_attributes }}
              >
                {% if block.settings.label != blank %}
                  <span class="bloomy-hero-banner__attribute-label">
                    {{ block.settings.label | escape }}
                  </span>
                {% endif %}

                {% if block.settings.icon_image != blank %}
                  {{
                    block.settings.icon_image
                    | image_url: width: 64
                    | image_tag:
                      class: 'bloomy-hero-banner__attribute-icon',
                      widths: '32, 64',
                      sizes: '24px',
                      loading: 'lazy',
                      alt: icon_alt
                  }}
                {% endif %}
              </div>
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Bloomy Hero Banner",
  "tag": "section",
  "class": "shopify-section--bloomy-hero-banner",
  "max_blocks": 6,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop banner image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile banner image"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Banner image alt text",
      "info": "Optional. Uses the selected image alt text when left empty."
    },
    {
      "type": "image_picker",
      "id": "badge_image",
      "label": "Badge image"
    },
    {
      "type": "text",
      "id": "badge_alt",
      "label": "Badge image alt text",
      "info": "Optional. Uses the uploaded image alt text when left empty."
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Safe, non-toxic\ntoys designed\nfor real\ndevelopment."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Feel confident about what your\nchild plays with."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "CTA label",
      "default": "SHOP BESTSELLERS"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "CTA link"
    }
  ],
  "blocks": [
    {
      "type": "attribute",
      "name": "Attribute item",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Non-toxic materials"
        },
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Icon image"
        },
        {
          "type": "text",
          "id": "icon_alt",
          "label": "Icon alt text",
          "info": "Optional. Uses the uploaded image alt text when left empty."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bloomy Hero Banner",
      "category": "t:categories.banners",
      "settings": {
        "heading": "Safe, non-toxic\ntoys designed\nfor real\ndevelopment.",
        "description": "Feel confident about what your\nchild plays with.",
        "button_label": "SHOP BESTSELLERS"
      },
      "blocks": [
        {
          "type": "attribute",
          "settings": {
            "label": "Non-toxic materials"
          }
        },
        {
          "type": "attribute",
          "settings": {
            "label": "Loved by parents"
          }
        },
        {
          "type": "attribute",
          "settings": {
            "label": "Designed for development"
          }
        }
      ]
    }
  ]
}
{% endschema %}
