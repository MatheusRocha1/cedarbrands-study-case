{{ 'section-bloomy-comparison-table.css' | asset_url | stylesheet_tag }}

{% liquid
  assign heading_id = 'BloomyComparisonTableHeading-' | append: section.id
  assign category_heading = section.settings.category_column_heading
  assign purposeful_heading = section.settings.purposeful_column_heading
  assign high_stimulation_heading = section.settings.high_stimulation_column_heading
%}

<div class="section-background bloomy-comparison-table__background"></div>

<div
  id="BloomyComparisonTable-{{ section.id }}"
  class="section section--page-width bloomy-comparison-table"
>
  {% if section.settings.heading != blank %}
    <h2
      id="{{ heading_id }}"
      class="bloomy-comparison-table__heading"
    >
      {{ section.settings.heading | escape }}
    </h2>
  {% endif %}

  {% if section.blocks.size > 0 %}
    <div class="bloomy-comparison-table__frame">
      <table
        class="bloomy-comparison-table__table"
        {% if section.settings.heading != blank %}
          aria-labelledby="{{ heading_id }}"
        {% else %}
          aria-label="Toy comparison"
        {% endif %}
      >
        <thead class="bloomy-comparison-table__head">
          <tr>
            <th scope="col">{{ category_heading | escape }}</th>
            <th scope="col">{{ purposeful_heading | escape }}</th>
            <th scope="col">{{ high_stimulation_heading | escape }}</th>
          </tr>
        </thead>

        <tbody>
          {% for block in section.blocks %}
            {% if block.settings.category != blank
              or block.settings.purposeful_text != blank
              or block.settings.high_stimulation_text != blank
            %}
              <tr {{ block.shopify_attributes }}>
                <th
                  class="bloomy-comparison-table__category"
                  scope="row"
                >
                  {{ block.settings.category | escape }}
                </th>
                <td>
                  <span class="bloomy-comparison-table__mobile-label">
                    {{ purposeful_heading | escape }}
                  </span>
                  <span class="bloomy-comparison-table__cell-text">
                    {{ block.settings.purposeful_text | escape | newline_to_br }}
                  </span>
                </td>
                <td>
                  <span class="bloomy-comparison-table__mobile-label">
                    {{ high_stimulation_heading | escape }}
                  </span>
                  <span class="bloomy-comparison-table__cell-text">
                    {{ block.settings.high_stimulation_text | escape | newline_to_br }}
                  </span>
                </td>
              </tr>
            {% endif %}
          {% endfor %}
        </tbody>
      </table>
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Bloomy Comparison Table",
  "tag": "section",
  "class": "shopify-section--bloomy-comparison-table",
  "max_blocks": 12,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How our toys compare"
    },
    {
      "type": "text",
      "id": "category_column_heading",
      "label": "Category column heading",
      "default": "Category"
    },
    {
      "type": "text",
      "id": "purposeful_column_heading",
      "label": "Purposeful play column heading",
      "default": "Our Purposeful Play Toys"
    },
    {
      "type": "text",
      "id": "high_stimulation_column_heading",
      "label": "High-stimulation column heading",
      "default": "High-Stimulation / Pre-Programmed Toys"
    }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Comparison row",
      "settings": [
        {
          "type": "text",
          "id": "category",
          "label": "Category",
          "default": "Core Purpose"
        },
        {
          "type": "textarea",
          "id": "purposeful_text",
          "label": "Purposeful play toys text",
          "default": "Learning through hands-on exploration"
        },
        {
          "type": "textarea",
          "id": "high_stimulation_text",
          "label": "High-stimulation toys text",
          "default": "Passive entertainment"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bloomy Comparison Table",
      "category": "t:categories.text",
      "settings": {
        "heading": "How our toys compare",
        "category_column_heading": "Category",
        "purposeful_column_heading": "Our Purposeful Play Toys",
        "high_stimulation_column_heading": "High-Stimulation / Pre-Programmed Toys"
      },
      "blocks": [
        {
          "type": "row",
          "settings": {
            "category": "Core Purpose",
            "purposeful_text": "Learning through hands-on exploration",
            "high_stimulation_text": "Passive entertainment"
          }
        },
        {
          "type": "row",
          "settings": {
            "category": "Materials",
            "purposeful_text": "Natural (wood, cotton, metal)",
            "high_stimulation_text": "Plastic, synthetic materials"
          }
        },
        {
          "type": "row",
          "settings": {
            "category": "Cognitive Development",
            "purposeful_text": "Encourages problem solving and creativity",
            "high_stimulation_text": "Limited interaction patterns"
          }
        },
        {
          "type": "row",
          "settings": {
            "category": "Creativity",
            "purposeful_text": "Open-ended play",
            "high_stimulation_text": "Fixed outcomes"
          }
        },
        {
          "type": "row",
          "settings": {
            "category": "Engagement Style",
            "purposeful_text": "Active (child-led play)",
            "high_stimulation_text": "Passive (toy-led play)"
          }
        },
        {
          "type": "row",
          "settings": {
            "category": "Motor Skill Development",
            "purposeful_text": "Develops fine motor skills through hands-on use",
            "high_stimulation_text": "Often limited to simple actions"
          }
        },
        {
          "type": "row",
          "settings": {
            "category": "Durability",
            "purposeful_text": "Long-lasting, multi-use",
            "high_stimulation_text": "Short lifespan"
          }
        },
        {
          "type": "row",
          "settings": {
            "category": "Environmental Impact",
            "purposeful_text": "Eco-friendly materials",
            "high_stimulation_text": "Higher waste"
          }
        },
        {
          "type": "row",
          "settings": {
            "category": "Safety",
            "purposeful_text": "Non-toxic, simple design",
            "high_stimulation_text": "May include electronics or small parts"
          }
        }
      ]
    }
  ]
}
{% endschema %}
