{{ 'section-bloomy-purposeful-play-banner.css' | asset_url | stylesheet_tag }}

{% liquid
  assign image_alt = section.settings.image_alt | strip
  assign fetch_priority = 'auto'
  assign loading = 'lazy'

  if image_alt == blank and section.settings.image != blank
    assign image_alt = section.settings.image.alt
  endif

  if section.index == 1
    assign fetch_priority = 'high'
    assign loading = 'eager'
  endif
%}

<div
  id="BloomyPurposefulPlayBanner-{{ section.id }}"
  class="section section--full-width bloomy-purposeful-play-banner"
>
  <div class="bloomy-purposeful-play-banner__media">
    {% if section.settings.image != blank %}
      {{
        section.settings.image
        | image_url: width: 2400
        | image_tag:
          class: 'bloomy-purposeful-play-banner__image',
          widths: '750, 900, 1200, 1600, 2000, 2400',
          sizes: '(min-width: 750px) 50vw, 100vw',
          loading: loading,
          fetchpriority: fetch_priority,
          alt: image_alt
      }}
    {% else %}
      {{ 'image' | placeholder_svg_tag: 'bloomy-purposeful-play-banner__placeholder' }}
    {% endif %}
  </div>

  <div class="bloomy-purposeful-play-banner__content">
    {% if section.settings.heading != blank %}
      <h2 class="bloomy-purposeful-play-banner__heading">
        {{ section.settings.heading | escape | newline_to_br }}
      </h2>
    {% endif %}

    {% if section.settings.lead != blank %}
      <p class="bloomy-purposeful-play-banner__lead">
        {{ section.settings.lead | escape | newline_to_br }}
      </p>
    {% endif %}

    {% if section.settings.body != blank %}
      <div class="bloomy-purposeful-play-banner__body">
        {{ section.settings.body | escape | newline_to_br }}
      </div>
    {% endif %}

    {% if section.settings.button_label != blank %}
      {% if section.settings.button_link != blank %}
        <a
          class="bloomy-purposeful-play-banner__button"
          href="{{ section.settings.button_link }}"
        >
          {{ section.settings.button_label | escape }}
        </a>
      {% else %}
        <span
          class="bloomy-purposeful-play-banner__button"
          aria-disabled="true"
        >
          {{ section.settings.button_label | escape }}
        </span>
      {% endif %}
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Bloomy Purposeful Play",
  "tag": "section",
  "class": "shopify-section--bloomy-purposeful-play-banner",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text",
      "info": "Optional. Uses the image alt text when left empty."
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "New to purposeful play?"
    },
    {
      "type": "textarea",
      "id": "lead",
      "label": "Lead text",
      "default": "Most parents are — and it can feel overwhelming."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body text",
      "default": "We simplify it with toys designed to keep your child engaged, learning, and growing."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "SHOP BESTSELLERS"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Bloomy Purposeful Play",
      "category": "t:categories.banners"
    }
  ]
}
{% endschema %}
